# ==========================================
# 1. BACKEND CONSTRAINTS (PocketBase)
# ==========================================

# Ignore the PocketBase executable (developers should download the binary for their specific OS)
/backend/pocketbase
/backend/pocketbase.exe

# CRITICAL: Ignore the raw database and uploaded physical files
# This prevents your actual images and private SQLite data from bloating the repo or going public
/backend/pb_data/

# NOTE: /backend/pb_migrations/ is intentionally NOT ignored. 
# This ensures your database schema travels with your code.


# ==========================================
# 2. FRONTEND CONSTRAINTS (Next.js)
# ==========================================

# Node Dependencies (These are generated locally via 'npm install')
/frontend/node_modules/
/frontend/.pnp
/frontend/.pnp.js
/frontend/migrate.js

# Next.js Build Outputs
/frontend/.next/
/frontend/out/
/frontend/build/

# Vercel deployment cache
/frontend/.vercel/

# Environment Variables (Never commit API keys or secrets)
/frontend/.env
/frontend/.env*.local


# ==========================================
# 3. SYSTEM & LOG FILES
# ==========================================

# OS Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*